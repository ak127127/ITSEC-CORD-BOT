# Discord bot token (from https://discord.com/developers/applications)
DISCORD_TOKEN=your_discord_token_here

# Discord Server/Guild ID (optional). Leave empty to allow any server.
GUILD_ID=

# Enable/disable CERT-SE feed and channel routing
ENABLE_CERT_SE=true

# Manage only the bot-owned ITSEC categories/channels
AUTO_CREATE_CATEGORIES=true
AUTO_CREATE_CHANNELS=true
AUTO_SET_CHANNEL_PERMISSIONS=true
ITSEC_LOG_READ_ONLY=true

# NVD API key (optional, recommended for higher rate limits)
# Request one at https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=your_nvd_api_key_here

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# SQLite database file
DB_PATH=itsec_cord_bot.db
