# Discord Bot Token (hamtas fran https://discord.com/developers/applications)
DISCORD_TOKEN=your_discord_token_here

# Discord Server/Guild ID (frivilligt - for auto-skapa kanaler)
GUILD_ID=your_guild_id_here

# NVD API Key (frivilligt men rekommenderat for hogre rate limits)
# Skapa pa https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=your_nvd_api_key_here

# Logg-niva (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# SQLite databasfil
DB_PATH=nemoclaw.db
